<% summary_name = @resume_data.summary.file %>
<% @summary = (eval("data.#{@active_resume_user}.summaries.#{summary_name}")).summary %>

<section class="section summary-section">
  <% if @resume_data.pdf.useicons %>
    <h2 class="section-title"><i class="fa fa-user"></i><%= display_name %></h2>
  <% else %>
    <h2 class="section-title"><%= display_name %></h2>
  <% end %>
  <div class="summary">
    <p><%= render_markdown(@summary.text) %></p>
  </div>
</section>
