<section class="section experience-other-section">
  <h2 class="section-title">
    <% if @resume_data.pdf.useicons %>
      <i class="fa fa-briefcase"></i>
    <% end %>
    <%= display_name %>
  </h2>

  <% @resume_data.jobs.each do |job| %>
    <% if job.section == 'experience_other' %>
        <% job = @jobs_by_id[job.id.to_s] %>
        <div class="meta">
          <%= partial 'templates/experience/company_name', :locals => {:job => job} %>
          <% if compact_title %>
            <% if job.title %>
              <div class="job-title-row">
                  <h3 class="job-title"><%= job.title %></h3>
              </div>
            <% end %>
          <% else %>
            <%= partial 'templates/experience/job_title', :locals => {:job => job} %>
          <% end %>
        </div>
    <% end %>
  <% end %>

</section>
