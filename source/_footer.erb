<% deployed_at = show_deployment_timestamp ? deployment_timestamp : nil %>
<% if deployed_at %>
  <footer class="footer deployment-footer">
    <div class="text-center">
      <small class="deployment-timestamp">
        Last deployed:
        <time datetime="<%= deployed_at.iso8601 %>"><%= deployed_at.strftime('%B %d, %Y at %I:%M %p %Z') %></time>
      </small>
    </div>
  </footer>
<% end %>

