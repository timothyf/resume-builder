<% active_theme = ENV.fetch('ACTIVE_RESUME_THEME', 'theme-default').strip %>
<% active_theme = 'theme-default' if active_theme.empty? %>
<% theme_variables_path = File.expand_path("_#{active_theme}.scss", __dir__) %>
<% unless File.exist?(theme_variables_path) %>
<%   active_theme = 'theme-default' %>
<%   theme_variables_path = File.expand_path("_#{active_theme}.scss", __dir__) %>
<% end %>
<%= File.read(theme_variables_path) %>
<%= File.read(File.expand_path('_base.scss', __dir__)) %>
<%= File.read(File.expand_path('_responsive.scss', __dir__)) %>
<%= File.read(File.expand_path('_print.scss', __dir__)) %>
<%= File.read(File.expand_path('_layout-overrides-screen.scss', __dir__)) %>
