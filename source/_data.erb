<% @resume_context = build_resume_context(data.active_resume) %>
<% @active_resume_user = @resume_context[:user] %>
<% @active_resume_name = @resume_context[:name] %>
<% @resume_data = @resume_context[:resume] %>
<% @layout_data = @resume_context[:layout] %>
<% @skills_data = @resume_context[:skills] %>
<% @job_data = @resume_context[:jobs] %>
<% @jobs_by_id = @job_data.each_with_object({}) { |job, index| index[job.id.to_s] = job } %>
